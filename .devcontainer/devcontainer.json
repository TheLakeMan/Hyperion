{
    "name": "Hyperion Development",
    "image": "mcr.microsoft.com/devcontainers/cpp:latest",
    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "version": "latest"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    "postCreateCommand": "pip install cpuinfo"
}